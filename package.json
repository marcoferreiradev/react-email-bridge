{
  "name": "react-email-bridge-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "tsx validation/test-pipeline.tsx",
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "pack-all": "pnpm build && mkdir -p dist-tarballs && pnpm --filter react-email-bridge exec pnpm pack --pack-destination ../../dist-tarballs && pnpm --filter react-email-bridge-ui exec pnpm pack --pack-destination ../../dist-tarballs",
    "new-project": "node scripts/new-project.mjs",
    "format": "biome check --write .",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.2",
    "typescript": "^5.6.0",
    "unrun": "^0.3.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "handlebars": "^4.7.8",
    "handlebars-helpers": "^0.10.0",
    "juice": "~11.1.0",
    "nanoid": "^5.0.7",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^6.1.4"
  }
}

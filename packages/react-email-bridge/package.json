{
  "name": "react-email-bridge",
  "version": "0.1.0",
  "description": "Write transactional emails in React Email, export to HTML with template markers (Handlebars, Liquid, Mailchimp). Live preview, real engine, copy-paste into VTEX, Mandrill, etc.",
  "type": "module",
  "license": "MIT",
  "author": "Marco Ferreira <marcoferreiradev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcoferreiradev/react-email-bridge.git",
    "directory": "packages/react-email-bridge"
  },
  "homepage": "https://github.com/marcoferreiradev/react-email-bridge#readme",
  "bugs": {
    "url": "https://github.com/marcoferreiradev/react-email-bridge/issues"
  },
  "keywords": [
    "react-email",
    "handlebars",
    "hbs",
    "vtex",
    "transactional-email",
    "mandrill",
    "mailchimp",
    "template",
    "preview"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "react-email-bridge": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./hbs": {
      "types": "./dist/hbs/index.d.mts",
      "import": "./dist/hbs/index.mjs"
    },
    "./hbs/preview-helpers": {
      "types": "./dist/hbs/preview-helpers.d.mts",
      "import": "./dist/hbs/preview-helpers.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0",
    "react-dom": "^18.0 || ^19.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "debounce": "^3.0.0",
    "esbuild": "^0.28.0",
    "handlebars": "^4.7.8",
    "handlebars-helpers": "^0.10.0",
    "jiti": "^2.4.0",
    "juice": "~11.1.0",
    "nanoid": "^5.0.7",
    "nypm": "^0.6.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "react-email": "^6.1.4",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/handlebars-helpers": "^0.5.6",
    "@types/prompts": "^2.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
